# OKX API credentials — copy to .env and fill in real values
# IMPORTANT: Never commit .env to version control
# API key should NOT have Withdraw permission; bind to static IP

OKX_API_KEY=your_api_key_here
OKX_SECRET=your_secret_here
OKX_PASSPHRASE=your_passphrase_here

# Telegram bot for alerts & remote kill switch
TELEGRAM_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Market-data ingestion / TimescaleDB
TIMESCALE_PASSWORD=changeme
DATABASE_URL=postgresql://quant:changeme@localhost:5432/okx_quant
REQUEST_TIMEOUT_SECONDS=20
HTTP_MAX_RETRIES=5
HTTP_BACKOFF_SECONDS=1.5
FLUSH_EVERY_REQUESTS=10
FLUSH_MAX_ROWS=50000
FLUSH_EVERY_SECONDS=60
